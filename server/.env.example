# SwipeSync Backend Environment Variables

# Required: The GCP/Firebase Project ID
FIREBASE_PROJECT_ID=your-project-id

# Required for Firebase Auth Config API
FIREBASE_API_KEY=your-api-key
FIREBASE_APP_ID=your-app-id
FIREBASE_MESSAGING_SENDER_ID=your-sender-id

# Optional: Overrides for Firebase config
# FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
# FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Required for GCS uploads
GCS_BUCKET_NAME=your-project-id-media

# Required for Production CORS (comma-separated list)
# ALLOWED_ORIGINS=https://swipesync.web.app,https://your-custom-domain.com

# Port for the express server (defaults to 8080)
PORT=8080
